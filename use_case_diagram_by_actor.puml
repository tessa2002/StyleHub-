@startuml Use_Case_Diagram_By_Actor

!define RECTANGLE(name) rectangle name ##[#FFAAAA]

' ============================================
' CUSTOMER USE CASES
' ============================================
RECTANGLE("Customer Use Cases") {
  actor Customer

  package "Authentication & Profile" {
    usecase "Register Account" as C1
    usecase "Login" as C2
    usecase "View Profile" as C3
    usecase "Update Profile" as C4
  }

  package "Measurements" {
    usecase "View Measurements" as C5
    usecase "Update Measurements" as C6
  }

  package "Orders" {
    usecase "Place Order" as C7
    usecase "View My Orders" as C8
    usecase "Track Order Status" as C9
    usecase "View Order Details" as C10
    usecase "Cancel Order" as C11
  }

  package "Appointments" {
    usecase "Book Appointment" as C12
    usecase "View Appointments" as C13
    usecase "Cancel Appointment" as C14
  }

  package "Payment" {
    usecase "View Bills" as C15
    usecase "Make Payment" as C16
    usecase "View Payment History" as C17
  }

  package "Catalog" {
    usecase "Browse Fabrics" as C18
    usecase "View Fabric Details" as C19
  }

  package "Notifications" {
    usecase "View Notifications" as C20
    usecase "Mark as Read" as C21
  }

  Customer --> C1
  Customer --> C2
  Customer --> C3
  Customer --> C4
  Customer --> C5
  Customer --> C6
  Customer --> C7
  Customer --> C8
  Customer --> C9
  Customer --> C10
  Customer --> C11
  Customer --> C12
  Customer --> C13
  Customer --> C14
  Customer --> C15
  Customer --> C16
  Customer --> C17
  Customer --> C18
  Customer --> C19
  Customer --> C20
  Customer --> C21

  C7 ..> C12 : <<extend>>
  C7 ..> C18 : <<extend>>
  C9 ..> C20 : <<extend>>
}

