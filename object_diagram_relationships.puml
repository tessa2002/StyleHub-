ord1 }o--|| fab1 : "N:1"
admin1 ||--o{ fab1 : "1:N"
cust1 ||--o{ apt1 : "1:N"
ord1 ||--o| apt1 : "1:1"
cust1 ||--o{ hist1 : "1:N"
ord1 ||--o{ notif1 : "1:N"
tailor1 ||--o{ notif1 : "1:N"

note right of user1
  User can be Customer,
  Admin, Tailor, or Staff
end note

note right of ord1
  Order has relationships
  with multiple entities
end note

